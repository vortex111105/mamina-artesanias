# ============================================
# MAMINA Artesanías — Variables de Entorno
# Copiar este archivo como .env.local y completar
# ============================================

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# MercadoPago (https://www.mercadopago.com.ar/developers)
# Usar credenciales de PRUEBA para desarrollo, PRODUCCIÓN para el deploy final
MP_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=clave_aleatoria_para_webhook_mp   # Generá una clave random y pegala en MP al configurar el webhook

# Links de la landing page
NEXT_PUBLIC_MP_LINK=https://mpago.la/tu-alias          # Link de transferencia MP directa
NEXT_PUBLIC_IG_LINK=https://instagram.com/tu_usuario   # Link al perfil de Instagram

# Instagram (para DMs de encargos de productos sin stock)
NEXT_PUBLIC_IG_USERNAME=mamina_artesanias              # Usuario de Instagram sin el @

# Telegram Bot (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_ADMIN_CHAT_ID=123456789       # Tu chat ID (manda /start al bot y buscá el id)
TELEGRAM_ALLOWED_USER_ID=123456789    # ID de la mamá (mismo que admin si es la misma persona)
TELEGRAM_WEBHOOK_SECRET=una_clave_secreta_aleatoria
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=mamina_artesanias_bot

# Email con Resend (https://resend.com)
# Plan gratis: 3000 emails/mes — crear cuenta y verificar dominio o usar onboarding@resend.dev para pruebas
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=MAMINA Artesanías <noreply@tudominio.com>
ADMIN_EMAIL=tu_mail@gmail.com          # Mail donde llegará el aviso de cada venta con dirección de envío

# App
NEXT_PUBLIC_APP_URL=https://mamina.vercel.app   # URL final en Vercel
INTERNAL_SECRET=otra_clave_secreta_para_api_interna
